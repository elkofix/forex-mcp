# ── LLM Provider ─────────────────────────────
# Opciones: openai | groq | google
LLM_PROVIDER=google

# ── Google ────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...
GOOGLE_MODEL=gemini-1.5-pro

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...
